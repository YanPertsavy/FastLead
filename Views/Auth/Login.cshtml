@model User
@{
    ViewData["Title"] = "Регистрация";
    Layout = null;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<style>
    body {
        background-color: #f4f7f9;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        margin: 0;
        font-family: sans-serif;
    }

    .auth-container {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 400px;
        border-top: 4px solid #f39c12; /* Оранжевая полоска сверху как в BPM */
    }

    h2 {
        color: #2c3e50;
        font-weight: bold;
        text-align: center;
        margin-bottom: 20px;
    }

    .form-control {
        border-radius: 6px;
        padding: 10px;
    }

    .btn-success {
        background-color: #27ae60;
        border: none;
        padding: 10px;
        font-weight: 600;
        margin-top: 10px;
    }

        .btn-success:hover {
            background-color: #219150;
        }

    .switch-link {
        display: block;
        text-align: center;
        margin-top: 15px;
        color: #7f8c8d;
        text-decoration: none;
        font-size: 0.9rem;
    }

        .switch-link:hover {
            color: #f39c12;
        }
</style>

<div class="auth-container">
    <h2>Вход в CRM</h2>
    <form id="loginForm">
        <div class="mb-3">
            <label class="form-label">Логин</label>
            <input type="text" id="logName" class="form-control" placeholder="Введите логин">
        </div>
        <div class="mb-3">
            <label class="form-label">Пароль</label>
            <input type="password" id="logPass" class="form-control" placeholder="••••••••">
        </div>
        <button type="button" onclick="submitLoging()" class="btn btn-success w-100">Войти</button>
    </form>
    <div id="message" class="mt-3"></div>
    <a href="/register" class="switch-link">Нет аккаунта? Регистрация</a>
</div>


    <script>
        async function submitLoging(){
            const data = {
                Name: document.getElementById("logName").value,
                Password: document.getElementById("logPass").value
            }
            console.log(data);
            const response = await fetch("/auth/login", {
                method: "POST",
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })

            const json = await response.json();
            const msgDiv = document.getElementById("message");

            if(response.ok)
            {
                window.location.href = "/Home/Accounts";
                localStorage.setItem("jwt_token", json.token);
            }
            else
            {
                msgDiv.innerHTML = `<div class="alert alert-danger">${json.message}</div>`;
            }
        }
    </script>