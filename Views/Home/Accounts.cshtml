@model Account
@{
    ViewData["Title"] = "Контрагенты";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1 text-dark fw-bold">Контрагенты</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Главная</a></li>
                <li class="breadcrumb-item active text-secondary">Все компании</li>
            </ol>
        </nav>
    </div>

    <div class="d-flex gap-2">
        <div class="dropdown">
            <button class="btn btn-outline-secondary shadow-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                <i class="bi bi-filter me-2"></i> Фильтры
            </button>
            <div class="dropdown-menu dropdown-menu-end border-0 p-3 shadow-lg" style="width: 300px;">
                <h6 class="mb-3 fw-bold">Фильтрация</h6>
                <div class="mb-2">
                    <label class="form-label small fw-bold text-muted">Поле поиска</label>
                    <select class="form-select form-select-sm" id="filterColumn">
                        <option value="Name">Name</option>
                        <option value="INN">INN</option>
                        <option value="Email">Email</option>
                        <option value="Owner">Owner</option>
                        <option value="Phone">Phone</option>
                        <option value="Address">Address</option>
                        <option value="Type">Type</option>
                    </select>
                </div>
                <div class="mb-2">
                    <label class="form-label small">Значение</label>
                    <input type="text" class="form-control form-control-sm" id="filterName">
                </div>
                <hr class="my-3">
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm w-100" onclick="getFilters()">Применить</button>
                    <button class="btn btn-light btn-sm w-100 border">Сброс</button>
                </div>
            </div>
        </div>

        <div class="dropdown">
            <button class="btn btn-success shadow-sm px-4 fw-bold dropdown-toggle" type="button" data-bs-toggle="dropdown">
                Действия
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                <li><a class="dropdown-item" href="javascript:void(0)" onclick="openCreateModal()"><i class="bi bi-plus-lg me-2"></i>Добавить контрагента</a></li>
                <li><a class="dropdown-item" href="javascript:void(0)" onclick="exportToExcel()"><i class="bi bi-file-earmark-excel me-2"></i>Экспорт в Excel</a></li>
                <li><a class="dropdown-item" href="javascript:void(0)" onclick="canselSelection()"><i class="bi bi-x-lg me-2"></i>Отменить выбор</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="bulkDelete()"><i class="bi bi-trash me-2"></i>Удалить выбранные</a></li>
            </ul>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive table-scroll-container">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small">
                <tr>
                    <th class="ps-4" style="width: 40px;">
                        <input type="checkbox" class="form-check-input" id="selectAll" onclick="toggleSelectAll(this)">
                    </th>
                    <th class="py-3">НАЗВАНИЕ КОМПАНИИ</th>
                    <th>ТИП</th>
                    <th>ОТРАСЛЬ</th>
                    <th class="text-end pe-4">ДЕЙСТВИЯ</th>
                </tr>
            </thead>
            <tbody id="accountsTableBody">
            </tbody>
        </table>
    </div>
</div>

<div id="editCard" class="card shadow-sm border-0 mt-4" style="display: none;">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 border-bottom">
        <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>Карточка: <span id="headerName">...</span></h5>
        <div id="cardActions">
            <button id="btnCancelClose" class="btn btn-light border btn-sm px-3" onclick="closeCard()">Закрыть</button>

            <div id="unsavedActions" style="display: none;">
                <button class="btn btn-success btn-sm px-3 me-1" onclick="saveChanges()">
                    <i class="bi bi-check-lg"></i> Сохранить
                </button>
                <button class="btn btn-outline-secondary btn-sm px-3" onclick="revertToOriginal()">
                    Отменить изменения
                </button>
            </div>
        </div>
    </div>
    <div class="card-body">
        <form id="editForm">
            <input type="hidden" id="editId">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">Название компании</label>
                        <input type="text" id="editName" class="form-control edit-field" placeholder="Введите название">
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">ИНН</label>
                        <input type="text" id="editINN" class="form-control edit-field" placeholder="10 или 12 цифр">
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">Email</label>
                        <input type="email" id="editEmail" class="form-control edit-field" placeholder="example@mail.com">
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">Телефон</label>
                        <input type="text" id="editPhone" class="form-control edit-field" placeholder="+7 (___) ___ - __ - __">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">Тип контрагента</label>
                        <select id="editType" class="form-select edit-field">
                            <option value="0">Клиент</option>
                            <option value="1">Партнер</option>
                            <option value="2">Поставщик</option>
                            <option value="3">Конкурент</option>
                            <option value="4">Перспективный</option>
                            <option value="5">Другое</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">Ответственный (Owner)</label>
                        <input type="text" id="editOwner" class="form-control edit-field">
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">Адрес</label>
                        <textarea id="editAddress" class="form-control edit-field" rows="4" placeholder="Полный адрес..."></textarea>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<script>
        document.addEventListener("DOMContentLoaded", () => 
        {
            loadAccounts();
        });

            async function loadAccounts() {
            const response = await fetch("/Home/getAccounts", {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        }
    });
        const json = await response.json();

        const tbody = document.getElementById("accountsTableBody");

        tbody.innerHTML = "";

        json.forEach(acc => {
            const firstLetter = acc.name ? acc.name.charAt(0).toUpperCase() : "?";

            const typeInfo = getAccountTypeInfo(acc.type);

            const row = `
                <tr id="row-${acc.id}">
                <td class="ps-4">
                    <input type="checkbox" class="form-check-input account-checkbox" value="${acc.id}">
                </td>
                <td>
                    <div class="d-flex align-items-center">
                        <div class="company-icon bg-primary text-white me-3">
                             ${firstLetter}
                        </div>
                        <div>
                            <a href="javascript:void(0)" onclick="openEditCard('${acc.id}')" class="text-decoration-none fw-bold text-primary d-block">
                                ${acc.name}
                            </a>
                            <small class="text-muted" style="font-size: 0.75rem;">ИНН: ${acc.inn || '—'}</small>
                        </div>
                    </div>
                </td>
                <td>
                    <span class="badge-custom ${typeInfo.class}">${typeInfo.text}</span>
                </td>
                <td>
                    <div class="text-secondary small">${acc.address || '—'}</div>
                </td>
                <td class="text-end pe-4">
                    <button class="btn btn-outline-danger btn-sm border-0" onclick="deleteAccount('${acc.id}')" title="Удалить">
                        <i class="bi bi-trash3"></i>
                    </button>
                </td>
            </tr>
            `;

            tbody.insertAdjacentHTML('beforeend', row);
        });
    }
        let accountBackup = {};

    async function deleteAccount(id)
    {
        const response = await fetch(`/Home/delete/${id}`, {
            method: "DELETE"
        });
        if(response.ok)
        {
            document.getElementById(`row-${id}`).remove();
        }
    }
    
    async function openEditCard(id) {
        const response = await fetch(`/Home/details/${id}`);
        const acc = await response.json();

        accountBackup = JSON.parse(JSON.stringify(acc));

        document.getElementById("editId").value = acc.id;
        document.getElementById("editName").value = acc.name || "";
        document.getElementById("headerName").innerText = acc.name || "Без имени";
        document.getElementById("editINN").value = acc.inn || "";
        document.getElementById("editEmail").value = acc.email || "";
        document.getElementById("editPhone").value = acc.phone || "";
        document.getElementById("editOwner").value = acc.owner || "";
        document.getElementById("editAddress").value = acc.address || "";
        document.getElementById("editType").value = acc.type;


        document.getElementById("editCard").style.display = "block";
        showUnsavedActions(false);

        document.getElementById("editCard").scrollIntoView({ behavior: 'smooth' });
    }

    document.querySelectorAll('.edit-field').forEach(input => {
        input.addEventListener('input', () => {
            const isChanged = checkAnyChanges();
            showUnsavedActions(isChanged);
        });
    });

    function checkAnyChanges() {
        return document.getElementById("editName").value !== (accountBackup.name || "") ||
               document.getElementById("editINN").value !== (accountBackup.inn || "") ||
               document.getElementById("editEmail").value !== (accountBackup.email || "") ||
               document.getElementById("editPhone").value !== (accountBackup.phone || "") ||
               document.getElementById("editOwner").value !== (accountBackup.owner || "") ||
               document.getElementById("editAddress").value !== (accountBackup.address || "") ||
               parseInt(document.getElementById("editType").value) !== accountBackup.type;
    }

    function showUnsavedActions(visible) {
        document.getElementById("btnCancelClose").style.display = visible ? "none" : "inline-block";
        document.getElementById("unsavedActions").style.display = visible ? "inline-block" : "none";
    }

    function revertToOriginal() {
        // Просто переоткрываем карту с теми же данными (или вручную возвращаем из backup)
        openEditCard(accountBackup.id);
    }

    function closeCard() {
        document.getElementById("editCard").style.display = "none";
    }
    
    async function saveChanges() {
        // Собираем объект из полей
        const updated = {
            Id: document.getElementById("editId").value,
            Name: document.getElementById("editName").value,
            INN: document.getElementById("editINN").value,
            Email: document.getElementById("editEmail").value,
            Phone: document.getElementById("editPhone").value,
            Owner: document.getElementById("editOwner").value,
            Address: document.getElementById("editAddress").value,
            Type: parseInt(document.getElementById("editType").value)
        };

        const res = await fetch('/Home/updateAccount', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updated)
        });

        if (res.ok) {
            loadAccounts(); // Обновляем основную таблицу
            showUnsavedActions(false);
            closeCard();
        }
    }

    function toggleSelectAll(MasterSelect)
    {
        if(MasterSelect.checked)
        {
            const table = document.getElementById("accountsTableBody");
            const checkboxes = table.querySelectorAll('input[type="checkbox"]');

            checkboxes.forEach(cb => cb.checked = true);
        }
    }

    function canselSelection()
    {
        const table = document.getElementById("accountsTableBody");
        const checkboxes = table.querySelectorAll('input[type="checkbox"]');

        checkboxes.forEach(cb => {
            cb.checked = false;
        });

        const selectAll = document.getElementById("selectAll");
        if (selectAll) {
            selectAll.checked = false;
        }
    }

    function getCheckedIds()
    {
        const table = document.getElementById("accountsTableBody");

        const checkboxes = table.querySelectorAll('input[type="checkbox"]');

            const ids = Array.from(checkboxes).reduce((acc, checkbox) => {
                 if (checkbox.checked) {
                    acc.push(checkbox.value);
                }
                return acc;
            }, []);
        return ids;
    }

    async function bulkDelete()
    {
        const ids = getCheckedIds();
        const response = await fetch("/Home/bulkDelete",{
            method: "DELETE",
            body: JSON.stringify(ids),
            headers: { 'Content-Type': 'application/json' }
        });

        if(response.ok)
        {
            ids.forEach(id => {
            var row = document.getElementById(`row-${id}`);
            if(row) row.remove();
        });
        }

    }

    async function exportToExcel()
    {
        const ids = getCheckedIds();
        const response = await fetch("/Home/getExel", {
            method: "POST",
            body: JSON.stringify(ids),
            headers: {
                'Content-Type': 'application/json'
            }
        })

        if(response.ok)
        {
            const blob = await response.blob();

            // Создаем временную ссылку в памяти браузера
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');

            a.href = url;
            a.download = "Контрагенты.xlsx"; // Имя файла для пользователя
            document.body.appendChild(a);
            a.click(); // Симулируем клик для скачивания

            // Чистим за собой
            window.URL.revokeObjectURL(url);
            a.remove();
        }

    }

    async function getFilters()
    {
       const params = new URLSearchParams({
            field: document.getElementById("filterColumn").value,
            value: document.getElementById("filterName").value
       });
        const response = await fetch(`/Home/GetFilters?${params.toString()}`)
        const jsonIds = await response.json();
        console.log(jsonIds);
        const tableBody = document.getElementById("accountsTableBody");
        const rows = tableBody.querySelectorAll("tr");

        rows.forEach(row =>{
            const rowGuid = row.id.replace('row-', '');

            if (!jsonIds.includes(rowGuid)) {
                 row.remove();
            }
        })
    }

    // Вспомогательная функция для маппинга Enum
        function getAccountTypeInfo(type) {
        switch (type) {
            case 0: // Client
                return { text: "Клиент", class: "bg-blue" };
            case 1: // Partner
                return { text: "Партнер", class: "bg-orange" };
            case 2: // Supplier
                return { text: "Поставщик", class: "bg-green" };
            case 3: // Competitor
                return { text: "Конкурент", class: "bg-red" };
            case 4: // Prospect
                return { text: "Перспективный", class: "bg-purple" };
            case 5: // Other
                return { text: "Другое", class: "bg-light text-dark" };
            default:
                return { text: "Не указан", class: "bg-light text-dark" };
        }
    }

</script>
<style>
    /* Базовые стили для CRM */
    .company-icon {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .badge-custom {
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .bg-blue {
        background-color: #eef6ff;
        color: #007bff;
    }

    .bg-orange {
        background-color: #fff4e5;
        color: #ff9800;
    }

    .bg-green {
        background-color: #e8fadf;
        color: #28a745;
    }

    .bg-red {
        background-color: #ffeef0;
        color: #dc3545;
    }

    .bg-purple {
        background-color: #f3efff;
        color: #6f42c1;
    }

    /* Стилизация выпадающего меню фильтров */
    .dropdown-menu {
        border-radius: 12px;
        margin-top: 10px !important;
    }

    .form-label {
        margin-bottom: 4px;
    }

    .table-hover tbody tr:hover {
        background-color: #f8fbff;
    }

    /* Ограничиваем высоту таблицы и включаем внутренний скролл */
    .table-scroll-container {
        max-height: 65vh; /* 65% высоты экрана, можно поставить в пикселях, например 500px */
        overflow-y: auto;
    }

    /* Фиксируем шапку таблицы, чтобы она не уезжала при скролле */
    .table thead th {
        position: sticky;
        top: 0;
        background-color: #f8f9fa !important; /* Цвет bg-light */
        z-index: 10;
        box-shadow: inset 0 -1px 0 #dee2e6; /* Имитация границы */
    }
</style>